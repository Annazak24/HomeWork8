services:
  selenoid1:
    image: aerokube/selenoid:1.11.3
    hostname: selenoid1
    networks:
      - selenoid1
    volumes:
      - "/var/run/docker.sock:/var/run/docker.sock"
      - "{{ selenoid_path }}/browsers.json:/etc/selenoid/browsers.json:ro"
    command: "-container-network selenoid1 -limit 10"

  selenoid2:
    image: aerokube/selenoid:1.11.3
    hostname: selenoid2
    networks:
      - selenoid2
    volumes:
      - "/var/run/docker.sock:/var/run/docker.sock"
      - "{{ selenoid_path }}/browsers.json:/etc/selenoid/browsers.json:ro"
    command: "-container-network selenoid2 -limit 10"

  ggr:
    image: aerokube/ggr:1.7.2
    hostname: ggr
    networks:
      - selenoid1
      - selenoid2
    volumes:
      - "{{ selenoid_path }}/grid-router:/etc/grid-router:ro"
    command: "-guests-allowed -guests-quota test -verbose"
    depends_on:
      - selenoid1
      - selenoid2

  nginx:
    image: nginx
    hostname: nginx
    ports:
      - "80:80"
    volumes:
      - "{{ selenoid_path }}/selenoid.conf:/etc/nginx/conf.d/default.conf:ro"
    networks:
      - selenoid1
    depends_on:
      - ggr

  jenkins:
    image: jenkins/jenkins:jdk21
    hostname: jenkins
    container_name: jenkins
    user: root
    ports:
      - "8081:8080"
      - "50000:50000"
    environment:
      - JENKINS_OPTS=--prefix=/my_jenkins
      - JAVA_OPTS=-Dhudson.model.DownloadService.noSignatureCheck=true
    volumes:
      - jenkins_home:/var/jenkins_home
      - "/var/run/docker.sock:/var/run/docker.sock"
    networks:
      - selenoid1
    restart: unless-stopped

networks:
  selenoid1:
    name: "{{ network1 }}"
    external: true
  selenoid2:
    name: "{{ network2 }}"
    external: true

volumes:
  jenkins_home: